{
  "name": "api-spec-studio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:web && npm run build:test",
    "build:test": "tsc -p tsconfig.test.json",
    "build:web": "vite build",
    "dev": "vite",
    "typecheck": "tsc -p tsconfig.app.json --noEmit && tsc -p tsconfig.test.json --noEmit",
    "test": "npm run build:test && node --test tests/**/*.test.mjs",
    "start": "vite preview --host --port 4173"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^5.0.4",
    "typescript": "^6.0.2",
    "vite": "^7.1.12"
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.6",
    "codemirror": "^6.0.1",
    "dockview": "^4.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
